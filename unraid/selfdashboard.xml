<?xml version="1.0"?>
<Container version="2">
  <Name>SelfDashboard</Name>
  <Repository>ghcr.io/kabelsalatundklartext/selfdashboard:latest</Repository>
  <Registry>https://github.com/kabelsalatundklartext/selfdashboard/pkgs/container/selfdashboard</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/kabelsalatundklartext/selfdashboard/issues</Support>
  <Project>https://github.com/kabelsalatundklartext/selfdashboard</Project>
  <Overview>SelfDashboard – A clean, modular, self-hosted dashboard with a plugin system. Add widgets for Unraid, Emby, WireGuard, Nextcloud, Immich, CrowdSec and more. Optional Docker socket mount (Advanced) enables the Docker container list on the same host only.</Overview>
  <Category>Tools: Status:Stable</Category>
  <WebUI>http://[IP]:[PORT:3000]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/kabelsalatundklartext/selfdashboard/main/unraid/selfdashboard.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/kabelsalatundklartext/selfdashboard/main/public/icon_unraid.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>

  <!-- Port -->
  <Config
    Name="WebUI Port"
    Target="3000"
    Default="3000"
    Mode="tcp"
    Description="Port for the SelfDashboard web interface."
    Type="Port"
    Display="always"
    Required="true"
    Mask="false">3000</Config>

  <!-- Timezone -->
  <Config
    Name="Timezone"
    Target="TZ"
    Default="Europe/Berlin"
    Mode=""
    Description="Your local timezone. Example: Europe/Berlin, America/New_York"
    Type="Variable"
    Display="always"
    Required="false"
    Mask="false">Europe/Berlin</Config>

  <!-- Data volume -->
  <Config
    Name="Config Storage"
    Target="/app/data"
    Default="/mnt/user/appdata/selfdashboard"
    Mode="rw"
    Description="Path where SelfDashboard stores its configuration and data."
    Type="Path"
    Display="always"
    Required="true"
    Mask="false">/mnt/user/appdata/selfdashboard</Config>

  <!-- Plugins volume (optional, for custom plugins) -->
  <Config
    Name="Custom Plugins Path"
    Target="/app/plugins/custom"
    Default="/mnt/user/appdata/selfdashboard/plugins"
    Mode="rw"
    Description="Optional: Mount a folder with your own custom plugins."
    Type="Path"
    Display="advanced"
    Required="false"
    Mask="false">/mnt/user/appdata/selfdashboard/plugins</Config>

  <!-- Docker Engine socket (optional — Docker widget, same host only) -->
  <Config
    Name="Docker Socket"
    Target="/var/run/docker.sock"
    Default="/var/run/docker.sock"
    Mode="ro"
    Description="Optional: same as -v /var/run/docker.sock:/var/run/docker.sock — host Docker socket read-only for the Docker widget. Only containers on THIS server (where SelfDashboard runs), not a remote Unraid/Docker."
    Type="Path"
    Display="advanced"
    Required="false"
    Mask="false">/var/run/docker.sock</Config>

  <!-- Node ENV -->
  <Config
    Name="Node Environment"
    Target="NODE_ENV"
    Default="production"
    Mode=""
    Description="Node.js environment. Leave as production."
    Type="Variable"
    Display="advanced"
    Required="false"
    Mask="false">production</Config>

</Container>
