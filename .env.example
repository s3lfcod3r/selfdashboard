# ══════════════════════════════════════════════════════════════════════════════
#  SelfDashboard — .env Konfiguration
#  cp .env.example .env  →  nano .env  →  docker compose up -d
# ══════════════════════════════════════════════════════════════════════════════

PORT=3000
POLL_INTERVAL=5000
TZ=Europe/Berlin

# ── Unraid Server (bis zu 3 Instanzen) ────────────────────────────────────────
UNRAID_1_NAME=Tower
UNRAID_1_HOST=http://192.168.1.10
UNRAID_1_API_KEY=

UNRAID_2_NAME=Tower2
UNRAID_2_HOST=
UNRAID_2_API_KEY=

UNRAID_3_NAME=
UNRAID_3_HOST=
UNRAID_3_API_KEY=

# ── AdGuard Home ───────────────────────────────────────────────────────────────
ADGUARD_URL=http://192.168.1.10:3000
ADGUARD_USER=admin
ADGUARD_PASSWORD=

# ── CrowdSec ───────────────────────────────────────────────────────────────────
CROWDSEC_URL=http://192.168.1.10:8080
CROWDSEC_API_KEY=

# ── Wetter ─────────────────────────────────────────────────────────────────────
# Open-Meteo: kein Key nötig, Koordinaten reichen
# OpenWeatherMap: kostenloser Key auf openweathermap.org
OPENWEATHER_KEY=

# ── Kalender ───────────────────────────────────────────────────────────────────
# Mehrere iCal URLs kommagetrennt (Nextcloud, Google Calendar, etc.)
ICAL_URLS=https://nextcloud.example.com/remote.php/dav/public-calendars/xxx/

# CalDAV (Nextcloud, Baikal, etc.)
CALDAV_URL=https://nextcloud.example.com/remote.php/dav
CALDAV_USER=
CALDAV_PASSWORD=
