PORT=3000
TZ=Europe/Berlin
POLL_INTERVAL=5000

# Unraid Server 1
UNRAID_1_NAME=Tower
UNRAID_1_HOST=http://192.168.1.10
UNRAID_1_API_KEY=

# Unraid Server 2 (optional)
UNRAID_2_NAME=
UNRAID_2_HOST=
UNRAID_2_API_KEY=

# Unraid Server 3 (optional)
UNRAID_3_NAME=
UNRAID_3_HOST=
UNRAID_3_API_KEY=

# AdGuard Home
ADGUARD_URL=http://192.168.1.10:3000
ADGUARD_USER=admin
ADGUARD_PASSWORD=

# CrowdSec  →  docker exec crowdsec cscli bouncers add selfdashboard
CROWDSEC_URL=http://192.168.1.10:8080
CROWDSEC_API_KEY=

# Weather  →  leave empty for Open-Meteo (free, no key)
OPENWEATHER_KEY=

# Calendar  →  comma-separated iCal URLs
ICAL_URLS=
CALDAV_URL=
CALDAV_USER=
CALDAV_PASSWORD=
